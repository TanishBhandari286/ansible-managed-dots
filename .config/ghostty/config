# ~/.config/ghostty/config

# Theme
theme = Rose Pine
term = xterm-256color

# Font (Change to your preferred Nerd Font)
font-family = "JetBrainsMono Nerd Font"
font-size = 21

# Hyprland-style Minimalism
window-decoration = false
window-padding-x = 10
window-padding-y = 10
background-opacity = 1.0

# Clipboard & Selection
clipboard-read = allow
clipboard-write = allow
copy-on-select = true
osc-52-copy = allow
osc-52-paste = allow

# Shell Integration (helps with SSH and prompt detection)
shell-integration = zsh

# Mouse support
mouse-hide-while-typing = false

# Behavior
cursor-style = block
cursor-style-blink = false
clipboard-read = unbuffered
clipboard-write = unbuffered
