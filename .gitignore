# =============================================================================
# .gitignore — Dotfiles Repository
# =============================================================================

# --- Ansible secrets ---------------------------------------------------------
# NEVER commit the vault password file or any unencrypted private keys
ansible/.vault_pass
*.vault_pass

# --- SSH private keys — encrypted with sops, never plaintext -----------------
ssh_keys/id_*
!ssh_keys/id_*.pub
!ssh_keys/id_*.enc

# --- Ansible runtime artifacts -----------------------------------------------
ansible/*.retry
ansible/.cache/
ansible/fact_cache/

# --- macOS artifacts ---------------------------------------------------------
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# --- Editors -----------------------------------------------------------------
*.swp
*.swo
*~
.idea/
.vscode/

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
.env
.venv/
